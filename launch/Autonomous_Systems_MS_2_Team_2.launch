<launch>
        <include file="$(find husky_gazebo)/launch/husky_empty_world.launch">
        </include>
        <include file="$(find husky_gazebo)/launch/spawn_husky.launch">
         <arg name="x" value="5.0"/>
         <arg name="y" value="2.0"/>
         <arg name="z" value="0.0"/>
         <arg name="yaw" value="0.0"/>
        </include>
        <node pkg="Autonomous_Systems_Project_Team_2" type="Autonomous_Systems_MS_2_OLR_Team_2.py" name="open_loop" output="screen">
	 <param name="x" value="1"/>
         <param name="y" value="0"/>
	 <param name="z" value="0"/>
         <param name="x_pos" value="5.0"/>
         <param name="y_pos" value="2.0"/>
         <param name="z_pos" value="0.0"/>
         <param name="yaw_pos" value="0.0"/>
	</node>
        <!--node pkg="Autonomous_Systems_Project_Team_2" type="Autonomous_Systems_MS_2_Teleop_Team_2.py" name="Teleport" output="screen">
         <param name="x_pos" value="5.0"/>
         <param name="y_pos" value="2.0"/>
         <param name="z_pos" value="0.0"/>
         <param name="yaw_pos" value="0.0"/>
        </node-->
	<node pkg="rqt_graph" type="rqt_graph" name="rqt_graph" output="screen">
	</node>
</launch>
